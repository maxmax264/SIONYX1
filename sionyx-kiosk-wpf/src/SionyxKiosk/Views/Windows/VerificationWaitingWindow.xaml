<Window x:Class="SionyxKiosk.Views.Windows.VerificationWaitingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="אימות טלפון" WindowState="Maximized" WindowStyle="None"
        ResizeMode="NoResize" Background="#0f1117" FlowDirection="RightToLeft">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="500">
            <TextBlock Text="📞" FontSize="80" HorizontalAlignment="Center" Margin="0,0,0,24"/>
            <TextBlock Text="החשבון שלך ממתין לאימות" FontSize="32" FontWeight="Bold"
                       Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,16"/>
            <TextBlock Text="כדי להיכנס למערכת, עליך לאמת את הטלפון שלך."
                       FontSize="18" Foreground="#aaaaaa" HorizontalAlignment="Center"
                       TextAlignment="Center" Margin="0,0,0,32"/>
            <Border Background="#1e2130" CornerRadius="12" Padding="32" Margin="0,0,0,32">
                <StackPanel>
                    <TextBlock Text="התקשר למספר:" FontSize="16" Foreground="#aaaaaa"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock x:Name="PhoneNumberText" Text="..." FontSize="42" FontWeight="Bold"
                               Foreground="#4f8ef7" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            <TextBlock Text="לאחר האימות הכניסה תתבצע אוטומטית" FontSize="14"
                       Foreground="#666" HorizontalAlignment="Center" Margin="0,0,0,24"/>
            <ProgressBar IsIndeterminate="True" Height="4" Background="#1e2130"
                         Foreground="#4f8ef7" Margin="0,0,0,32"/>
            <Button x:Name="LogoutButton" Content="חזור למסך הכניסה" FontSize="16"
                    Padding="24,12" HorizontalAlignment="Center"
                    Background="Transparent" Foreground="#aaaaaa"
                    BorderBrush="#333" BorderThickness="1" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
