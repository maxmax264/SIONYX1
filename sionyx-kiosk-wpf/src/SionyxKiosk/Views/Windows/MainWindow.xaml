<Window x:Class="SionyxKiosk.Views.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SionyxKiosk.Views.Controls"
        Title="SIONYX"
        WindowState="Maximized" Topmost="True"
        WindowStyle="None" ResizeMode="NoResize"
        FlowDirection="RightToLeft">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0" Background="{StaticResource SidebarGradient}"
                BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Brand + user info -->
                <Border DockPanel.Dock="Top" Padding="20,24,20,20"
                        BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="SIONYX" FontSize="24" FontWeight="Bold"
                                       FontFamily="Segoe UI" FlowDirection="LeftToRight"
                                       HorizontalAlignment="Center">
                                <TextBlock.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#4338CA" Offset="0" />
                                        <GradientStop Color="#6366F1" Offset="0.5" />
                                        <GradientStop Color="#8B5CF6" Offset="1" />
                                    </LinearGradientBrush>
                                </TextBlock.Foreground>
                            </TextBlock>
                            <TextBlock Text="מערכת ניהול זמן" FontSize="11"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       HorizontalAlignment="Center" Margin="0,2,0,0" />
                        </StackPanel>
                        <Border Height="1" Background="{StaticResource BorderLightBrush}" Margin="0,0,0,16" />
                        <StackPanel Orientation="Horizontal">
                            <Border Width="42" Height="42" CornerRadius="21"
                                    Background="{StaticResource PrimaryGradient}" Margin="0,0,12,0">
                                <TextBlock x:Name="AvatarInitials" Text="?" FontSize="16"
                                           FontWeight="SemiBold" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding CurrentUser.FullName}" FontSize="14"
                                           FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="{Binding CurrentUser.PhoneNumber}" FontSize="12"
                                           Foreground="{StaticResource TextMutedBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Logout button at bottom -->
                <Border DockPanel.Dock="Bottom" Padding="14,14">
                    <Button AutomationProperties.AutomationId="LogoutButton" Style="{StaticResource BtnDanger}"
                            Command="{Binding LogoutCommand}"
                            IsEnabled="{Binding IsLoggingOut, Converter={StaticResource InverseBool}}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="16" Foreground="White"
                                       VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="התנתק" VerticalAlignment="Center"
                                       FontSize="14" FontWeight="SemiBold" />
                        </StackPanel>
                    </Button>
                </Border>

                <!-- Nav items -->
                <StackPanel Margin="10,14,10,0">
                    <RadioButton x:Name="NavHome" AutomationProperties.AutomationId="NavHome" Tag="Home"
                                 Style="{StaticResource SidebarNavButton}" IsChecked="True"
                                 Checked="NavButton_Checked" GroupName="Nav">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0" />
                            <TextBlock Text="בית" FontSize="15" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavPackages" AutomationProperties.AutomationId="NavPackages" Tag="Packages"
                                 Style="{StaticResource SidebarNavButton}"
                                 Checked="NavButton_Checked" GroupName="Nav">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE719;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0" />
                            <TextBlock Text="חבילות" FontSize="15" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavHistory" AutomationProperties.AutomationId="NavHistory" Tag="History"
                                 Style="{StaticResource SidebarNavButton}"
                                 Checked="NavButton_Checked" GroupName="Nav">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0" />
                            <TextBlock Text="היסטוריה" FontSize="15" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavPrintHistory" AutomationProperties.AutomationId="NavPrintHistory" Tag="PrintHistory"
                                 Style="{StaticResource SidebarNavButton}"
                                 Checked="NavButton_Checked" GroupName="Nav">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE749;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0" />
                            <TextBlock Text="הדפסות" FontSize="15" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavHelp" AutomationProperties.AutomationId="NavHelp" Tag="Help"
                                 Style="{StaticResource SidebarNavButton}"
                                 Checked="NavButton_Checked" GroupName="Nav">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE897;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0" />
                            <TextBlock Text="עזרה" FontSize="15" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Column="1" Background="{StaticResource BgPrimaryBrush}">
            <Frame x:Name="ContentFrame" NavigationUIVisibility="Hidden" Margin="28,24" />

            <!-- Toast overlay (top of content area) -->
            <controls:ToastNotification x:Name="Toast"
                                        HorizontalAlignment="Center" VerticalAlignment="Top"
                                        Margin="0,16,0,0" Panel.ZIndex="100" />
        </Grid>
    </Grid>
</Window>
