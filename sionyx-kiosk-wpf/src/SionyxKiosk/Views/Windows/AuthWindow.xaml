<Window x:Class="SionyxKiosk.Views.Windows.AuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SIONYX - כניסה"
        WindowState="Maximized" ResizeMode="NoResize"
        WindowStyle="None" Topmost="True"
        FlowDirection="RightToLeft">

    <Window.Resources>
        <Storyboard x:Key="SlideToLogin">
            <DoubleAnimation Storyboard.TargetName="BrandOverlay"
                             Storyboard.TargetProperty="(Canvas.Left)"
                             To="-3" Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseInOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="LoginPanel"
                             Storyboard.TargetProperty="Opacity"
                             To="1" Duration="0:0:0.35" BeginTime="0:0:0.15" />
            <DoubleAnimation Storyboard.TargetName="RegisterPanel"
                             Storyboard.TargetProperty="Opacity"
                             To="0" Duration="0:0:0.2" />
        </Storyboard>
        <Storyboard x:Key="SlideToRegister">
            <DoubleAnimation Storyboard.TargetName="BrandOverlay"
                             Storyboard.TargetProperty="(Canvas.Left)"
                             To="500" Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseInOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="RegisterPanel"
                             Storyboard.TargetProperty="Opacity"
                             To="1" Duration="0:0:0.35" BeginTime="0:0:0.15" />
            <DoubleAnimation Storyboard.TargetName="LoginPanel"
                             Storyboard.TargetProperty="Opacity"
                             To="0" Duration="0:0:0.2" />
        </Storyboard>
        <Style x:Key="BtnPrimaryDynamic" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                CornerRadius="12"
                                Background="{Binding DataContext.ButtonGradient, RelativeSource={RelativeSource AncestorType=Window}}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#D1D5DB" />
                                <Setter TargetName="border" Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource AuthPageBg}">
        <!-- Bottom-left version watermark -->
        <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Left"
                    Margin="16,0,0,12" Orientation="Horizontal" Panel.ZIndex="10">
            <TextBlock Text="SIONYX" FontSize="12" FontWeight="Bold"
                       Foreground="#99FFFFFF" Margin="0,0,6,0" />
            <TextBlock Text="{Binding AppVersion}" FontSize="12"
                       Foreground="#66FFFFFF" />
        </StackPanel>

        <Image x:Name="BgImage"
               Source="{Binding BackgroundImageSource}"
               Stretch="{Binding BgStretch}"
               Visibility="{Binding HasBackgroundImage, Converter={StaticResource BoolToVis}}"
               Opacity="{Binding BgOpacity}" Panel.ZIndex="0" />
        <Viewbox Stretch="Uniform" StretchDirection="DownOnly"
                 MaxHeight="700">
            <Viewbox.Style>
                <Style TargetType="Viewbox">
                    <Setter Property="HorizontalAlignment" Value="Center"/>
                    <Setter Property="VerticalAlignment" Value="Center"/>
                    <Setter Property="MaxWidth" Value="1000"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CleanMode}" Value="True">
                            <Setter Property="HorizontalAlignment" Value="Left"/>
                            <Setter Property="VerticalAlignment" Value="Top"/>
                            <Setter Property="Margin" Value="{Binding FormMargin}"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Viewbox.Style>
        <Border CornerRadius="20" ClipToBounds="True"
                Background="White">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Width" Value="1000"/>
                    <Setter Property="Height" Value="700"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CleanMode}" Value="True">
                            <Setter Property="Width" Value="500"/>
                            <Setter Property="Height" Value="700"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Border.Effect>
                <DropShadowEffect BlurRadius="120" ShadowDepth="0" Opacity="0.35" Color="#6366F1" />
            </Border.Effect>

            <Canvas FlowDirection="LeftToRight">
                <!-- LOGIN form -->
                <StackPanel x:Name="LoginPanel" Canvas.Top="0"
                            Width="500" Height="700" Opacity="1"
                            FlowDirection="RightToLeft">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Canvas.Left" Value="500"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CleanMode}" Value="True">
                                    <Setter Property="Canvas.Left" Value="0"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Height="700">
                        <StackPanel VerticalAlignment="Center" Margin="60,60">
                            <TextBlock Text="SIONYX" FontSize="28" FontWeight="ExtraBold"
                                       Foreground="{Binding OverlayGradient}"
                                       HorizontalAlignment="Center" Margin="0,0,0,20"
                                       Visibility="{Binding CleanMode, Converter={StaticResource BoolToVis}}" />
                            <TextBlock Text="{Binding WelcomeText}" Style="{StaticResource TextH1}" Margin="0,0,0,6" />
                            <TextBlock Text="{Binding WelcomeSubtext}"
                                       Style="{StaticResource TextSubtitle}" Margin="0,0,0,36" />

                            <TextBlock Text="מספר טלפון" Style="{StaticResource TextCaption}" Margin="0,0,0,6" />
                            <TextBox x:Name="LoginPhoneInput" AutomationProperties.AutomationId="LoginPhoneInput"
                                     Style="{StaticResource FrostInput}"
                                     Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,18" />

                            <TextBlock Text="סיסמה" Style="{StaticResource TextCaption}" Margin="0,0,0,6" />
                            <PasswordBox x:Name="LoginPasswordInput" AutomationProperties.AutomationId="LoginPasswordInput"
                                         Style="{StaticResource FrostPasswordBox}"
                                         Margin="0,0,0,8" />

                            <TextBlock x:Name="LoginError" AutomationProperties.AutomationId="LoginErrorText" Text="{Binding ErrorMessage}"
                                       Foreground="{StaticResource ErrorBrush}" FontSize="{StaticResource FontSizeSm}"
                                       Margin="0,8,0,0" TextWrapping="Wrap"
                                       Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVis}}" />

                            <Button x:Name="LoginButton" AutomationProperties.AutomationId="LoginButton"
                                    Content="{Binding LoginButtonText}"
                                    Style="{StaticResource BtnPrimaryDynamic}"
                                    Command="{Binding LoginCommand}" Margin="0,24,0,0"
                                    IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBool}}" />

                            <Button AutomationProperties.AutomationId="ForgotPasswordLink" Content="שכחת סיסמה?"
                                    Style="{StaticResource BtnGhost}" Margin="0,8,0,0"
                                    Command="{Binding ForgotPasswordCommand}"
                                    IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBool}}" />
                            <TextBlock Text="{Binding ForgotPasswordInfo}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="{StaticResource FontSizeSm}"
                                       TextWrapping="Wrap" Margin="0,4,0,0"
                                       Visibility="{Binding ForgotPasswordInfo, Converter={StaticResource StringToVis}}" />

                            <Button AutomationProperties.AutomationId="SwitchToRegisterLink" Content="אין לך חשבון? הירשם"
                                    Style="{StaticResource BtnGhost}" Margin="0,12,0,0"
                                    Click="ToggleToRegister_Click"
                                    Visibility="{Binding ShowRegister, Converter={StaticResource BoolToVis}}" />
                        </StackPanel>
                    </ScrollViewer>
                </StackPanel>

                <!-- REGISTER form -->
                <StackPanel x:Name="RegisterPanel" Canvas.Left="0" Canvas.Top="0"
                            Width="500" Height="700" Opacity="0" IsHitTestVisible="False"
                            FlowDirection="RightToLeft">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Height="700">
                        <StackPanel VerticalAlignment="Center" Margin="60,40">
                            <TextBlock Text="ברוכים הבאים" Style="{StaticResource TextH1}" Margin="0,0,0,6" />
                            <TextBlock Text="צור חשבון חדש"
                                       Style="{StaticResource TextSubtitle}" Margin="0,0,0,30" />

                            <TextBlock Text="מספר טלפון" Style="{StaticResource TextCaption}" Margin="0,0,0,6" />
                            <TextBox x:Name="RegPhoneInput" AutomationProperties.AutomationId="RegPhoneInput" Style="{StaticResource FrostInput}"
                                     Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,14" />

                            <TextBlock Text="סיסמה" Style="{StaticResource TextCaption}" Margin="0,0,0,6" />
                            <PasswordBox x:Name="RegPasswordInput" AutomationProperties.AutomationId="RegPasswordInput" Style="{StaticResource FrostPasswordBox}"
                                         Margin="0,0,0,14" />

                            <TextBlock Text="שם פרטי" Style="{StaticResource TextCaption}" Margin="0,0,0,6" />
                            <TextBox AutomationProperties.AutomationId="RegFirstNameInput" Style="{StaticResource FrostInput}"
                                     Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,14" />

                            <TextBlock Text="שם משפחה" Style="{StaticResource TextCaption}" Margin="0,0,0,6" />
                            <TextBox AutomationProperties.AutomationId="RegLastNameInput" Style="{StaticResource FrostInput}"
                                     Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />

                            <TextBlock Text="{Binding ErrorMessage}"
                                       Foreground="{StaticResource ErrorBrush}" FontSize="{StaticResource FontSizeSm}"
                                       Margin="0,8,0,0" TextWrapping="Wrap"
                                       Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVis}}" />

                            <Button x:Name="RegisterButton" AutomationProperties.AutomationId="RegisterButton" Content="{Binding RegisterButtonText}"
                                    Style="{StaticResource BtnPrimaryDynamic}"
                                    Command="{Binding RegisterCommand}" Margin="0,20,0,0"
                                    IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBool}}" />

                            <Button AutomationProperties.AutomationId="SwitchToLoginLink" Content="יש לך חשבון? התחבר"
                                    Style="{StaticResource BtnGhost}" Margin="0,10,0,0"
                                    Click="ToggleToLogin_Click" />
                        </StackPanel>
                    </ScrollViewer>
                </StackPanel>

                <!-- BRAND OVERLAY -->
                <Border x:Name="BrandOverlay" Canvas.Left="-3" Canvas.Top="-3"
                        Visibility="{Binding CleanMode, Converter={StaticResource InverseBoolToVis}}"
                        Width="503" Height="706"
                        CornerRadius="20"
                        Background="{Binding OverlayGradient}">
                    <Grid>
                        <!-- Logo + subtitle in center -->
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="48"
                                    Visibility="{Binding CleanMode, Converter={StaticResource InverseBoolToVis}}">
                            <TextBlock Text="SIONYX" FontSize="46" FontWeight="ExtraBold"
                                       Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,16" />
                            <TextBlock x:Name="BrandSubtitleBlock" Text="{Binding BrandSubtitle}" FontSize="18"
                                       Foreground="#DDFFFFFF" HorizontalAlignment="Center"
                                       TextAlignment="Center" FontWeight="Light" />
                        </StackPanel>

                        <!-- Version number bottom center -->
                        <TextBlock Text="{Binding AppVersion}"
                                   VerticalAlignment="Bottom"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,20"
                                   FontSize="13"
                                   Foreground="#88FFFFFF"
                                   FontWeight="Light" />
                    </Grid>
                </Border>
            </Canvas>
        </Border>
        </Viewbox>
    </Grid>
</Window>
