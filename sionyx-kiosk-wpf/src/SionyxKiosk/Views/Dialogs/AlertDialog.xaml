<Window x:Class="SionyxKiosk.Views.Dialogs.AlertDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterOwner" SizeToContent="WidthAndHeight"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        MaxWidth="480" MinWidth="380" FlowDirection="RightToLeft">

    <!-- Outer padding so the shadow has room to render outside the card -->
    <Border Padding="24">
        <Border CornerRadius="20" Background="White" ClipToBounds="False">
            <Border.Effect>
                <DropShadowEffect BlurRadius="48" ShadowDepth="12" Direction="270"
                                  Color="#0F172A" Opacity="0.22" />
            </Border.Effect>
            <Grid>
                <!-- Clipped inner content (so header corners are rounded) -->
                <Border CornerRadius="20" ClipToBounds="True">
                    <StackPanel>
                        <!-- Header with gradient + centered icon -->
                        <Border x:Name="HeaderBorder" Padding="32,28"
                                Background="{StaticResource HeroGradient}">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock x:Name="IconText" Text="ℹ️" FontSize="36"
                                           HorizontalAlignment="Center" Margin="0,0,0,10" />
                                <TextBlock x:Name="TitleText" Text="הודעה"
                                           FontSize="22" FontWeight="Bold" Foreground="White"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <!-- Body -->
                        <TextBlock x:Name="BodyText" Text="" Margin="32,28,32,24" TextWrapping="Wrap"
                                   FontSize="16" LineHeight="26" TextAlignment="Center"
                                   Foreground="{StaticResource TextPrimaryBrush}" />

                        <!-- Separator line -->
                        <Border Height="1" Background="#E8ECF4" Margin="24,0" />

                        <!-- Actions -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="32,20,32,28">
                            <Button x:Name="OkButton" AutomationProperties.AutomationId="AlertConfirmButton" Content="אישור" Style="{StaticResource BtnPrimary}"
                                    Width="140" Height="44" FontSize="16" Click="OkButton_Click" />
                            <Button x:Name="CancelButton" AutomationProperties.AutomationId="AlertCancelButton" Content="ביטול" Style="{StaticResource BtnGhost}"
                                    Width="140" Height="44" FontSize="16"
                                    Margin="12,0,0,0" Click="CancelButton_Click" Visibility="Collapsed" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Border>
</Window>
