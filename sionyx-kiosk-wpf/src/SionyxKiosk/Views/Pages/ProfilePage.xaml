<Page x:Class="SionyxKiosk.Views.Pages.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="clr-namespace:SionyxKiosk.Views.Controls"
      Title="פרופיל" FlowDirection="RightToLeft">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <controls:PageHeader Grid.Row="0" Title="פרופיל" Subtitle="עדכון פרטים אישיים וסיסמה"
                             HeaderBrush="{StaticResource PrimaryGradient}" Icon="&#xE77B;"
                             Margin="0,0,0,24" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="600" HorizontalAlignment="Right">

                <!-- פרטים אישיים -->
                <Border Background="White" CornerRadius="{StaticResource RadiusLg}"
                        Padding="32,28" Margin="0,0,0,20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="4" Direction="270"
                                          Color="#0F172A" Opacity="0.07" />
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="פרטים אישיים" Style="{StaticResource TextH3}" Margin="0,0,0,20" />

                        <TextBlock Text="שם פרטי" FontSize="13" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6" />
                        <TextBox Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}" Margin="0,0,0,16" />

                        <TextBlock Text="שם משפחה" FontSize="13" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6" />
                        <TextBox Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}" Margin="0,0,0,16" />

                        <TextBlock Text="טלפון" FontSize="13" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6" />
                        <TextBox Text="{Binding PhoneNumber}" IsReadOnly="True"
                                 Style="{StaticResource ModernTextBox}" Opacity="0.6" Margin="0,0,0,24" />

                        <Button Content="שמור פרטים" Style="{StaticResource BtnPrimary}"
                                Command="{Binding SaveDetailsCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                                HorizontalAlignment="Left" />
                    </StackPanel>
                </Border>

                <!-- שינוי סיסמה -->
                <Border Background="White" CornerRadius="{StaticResource RadiusLg}"
                        Padding="32,28" Margin="0,0,0,20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="4" Direction="270"
                                          Color="#0F172A" Opacity="0.07" />
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="שינוי סיסמה" Style="{StaticResource TextH3}" Margin="0,0,0,20" />

                        <TextBlock Text="סיסמה חדשה" FontSize="13" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6" />
                        <PasswordBox x:Name="NewPasswordBox" Style="{StaticResource ModernPasswordBox}"
                                     Margin="0,0,0,16" PasswordChanged="NewPasswordBox_Changed" />

                        <TextBlock Text="אישור סיסמה" FontSize="13" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6" />
                        <PasswordBox x:Name="ConfirmPasswordBox" Style="{StaticResource ModernPasswordBox}"
                                     Margin="0,0,0,24" PasswordChanged="ConfirmPasswordBox_Changed" />

                        <Button Content="שנה סיסמה" Style="{StaticResource BtnPrimary}"
                                Command="{Binding ChangePasswordCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                                HorizontalAlignment="Left" />
                    </StackPanel>
                </Border>

                <!-- הודעת סטטוס -->
                <Border Padding="16,12" CornerRadius="{StaticResource RadiusLg}" Margin="0,0,0,20">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding StatusMessage}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Border.Background>
                        <SolidColorBrush Color="#F0FDF4" />
                    </Border.Background>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource SuccessBrush}" TextWrapping="Wrap" />
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
