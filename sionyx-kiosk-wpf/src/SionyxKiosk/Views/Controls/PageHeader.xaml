<UserControl x:Class="SionyxKiosk.Views.Controls.PageHeader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:SionyxKiosk.Views.Controls"
             x:Name="Root">
    <UserControl.Resources>
        <local:StringToVisibilityConverter x:Key="StringToVisibility" />
    </UserControl.Resources>
    <Border x:Name="HeaderBorder" CornerRadius="{StaticResource RadiusXl}" Padding="40,28"
            Background="{StaticResource HeroGradient}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="{Binding Title, ElementName=Root}"
                           FontSize="{StaticResource FontSize3Xl}" FontWeight="Bold"
                           Foreground="White" />
                <TextBlock Text="{Binding Subtitle, ElementName=Root}"
                           FontSize="{StaticResource FontSizeLg}" Foreground="#E0E7FF"
                           Margin="0,6,0,0"
                           Visibility="{Binding Subtitle, ElementName=Root, Converter={StaticResource StringToVisibility}}" />
            </StackPanel>

            <TextBlock Grid.Column="1"
                       Text="{Binding Icon, ElementName=Root}"
                       FontSize="48" Foreground="#FFFFFF" Opacity="0.3"
                       VerticalAlignment="Center"
                       Visibility="{Binding Icon, ElementName=Root, Converter={StaticResource StringToVisibility}}" />
        </Grid>
    </Border>
</UserControl>
