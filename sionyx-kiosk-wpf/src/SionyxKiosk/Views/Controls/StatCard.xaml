<UserControl x:Class="SionyxKiosk.Views.Controls.StatCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="220" Height="140">
    <Border Background="White" CornerRadius="{StaticResource RadiusLg}" Padding="24,20"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Direction="270"
                              Color="#0F172A" Opacity="0.08" />
        </Border.Effect>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Colored icon circle -->
            <Border Grid.Column="0" Width="52" Height="52" CornerRadius="14"
                    VerticalAlignment="Center" Margin="0,0,18,0">
                <Border.Background>
                    <SolidColorBrush Color="{Binding AccentBgColor, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                </Border.Background>
                <TextBlock Text="{Binding Icon, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock.Foreground>
                        <SolidColorBrush Color="{Binding AccentColor, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                    </TextBlock.Foreground>
                </TextBlock>
            </Border>

            <!-- Title + Value -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           FontSize="{StaticResource FontSizeSm}" FontWeight="Medium"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,6" />
                <TextBlock Text="{Binding Value, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           FontSize="28" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
