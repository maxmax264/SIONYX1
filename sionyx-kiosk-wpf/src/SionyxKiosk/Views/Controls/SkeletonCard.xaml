<UserControl x:Class="SionyxKiosk.Views.Controls.SkeletonCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="White" CornerRadius="14" Padding="24,20" Margin="0,0,0,12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" ShadowDepth="2" Direction="270" Color="#0F172A" Opacity="0.04" />
        </Border.Effect>
        <StackPanel>
            <!-- Title skeleton -->
            <Border x:Name="TitleBar" Background="#E8ECF0" CornerRadius="6"
                    Height="16" Width="180" HorizontalAlignment="Right" Margin="0,0,0,14">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="TitleShimmer" X="0" />
                </Border.RenderTransform>
            </Border>
            <!-- Content skeleton lines -->
            <Border Background="#F1F5F9" CornerRadius="6"
                    Height="12" HorizontalAlignment="Stretch" Margin="0,0,0,10" />
            <Border Background="#F1F5F9" CornerRadius="6"
                    Height="12" Width="260" HorizontalAlignment="Right" Margin="0,0,0,10" />
            <Border Background="#F1F5F9" CornerRadius="6"
                    Height="12" Width="200" HorizontalAlignment="Right" />
        </StackPanel>
    </Border>
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard RepeatBehavior="Forever">
                    <DoubleAnimation Storyboard.TargetName="TitleBar"
                                     Storyboard.TargetProperty="Opacity"
                                     From="1" To="0.4" Duration="0:0:0.8"
                                     AutoReverse="True" />
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>
</UserControl>
